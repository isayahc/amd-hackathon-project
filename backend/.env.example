# Example environment configuration for AG2 backend
# Copy this file to .env and fill in your own values

# ============================================================================
# LLM PROVIDER SELECTION
# ============================================================================
# Choose which LLM provider to use: "openai" or "gemini"
LLM_PROVIDER=openai

# ============================================================================
# OPENAI CONFIGURATION (if LLM_PROVIDER=openai)
# ============================================================================
OPENAI_API_KEY=sk-proj-your-openai-key-here
OPENAI_MODEL=gpt-4.1

# ============================================================================
# GOOGLE GEMINI CONFIGURATION (if LLM_PROVIDER=gemini)
# ============================================================================

# Option A: Using Direct API Key (simplest)
# Get your API key at: https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=your-google-genai-key-here
# GEMINI_MODEL=gemini-2.5-flash

# Option B: Using Google Cloud Project
# Get your credentials from: https://console.cloud.google.com
# GEMINI_PROJECT_ID=your-awesome-google-cloud-project-id
# GEMINI_LOCATION=us-west1
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
# GEMINI_MODEL=gemini-2.5-flash

# ============================================================================
# OTHER AGENT SETTINGS
# ============================================================================
AGENT_TEMPERATURE=0.1

# ============================================================================
# METADATA STORAGE
# ============================================================================
# local uses SQLite at backend/storage/app.db.
# postgres and supabase use SQLAlchemy-compatible PostgreSQL URLs.
METADATA_BACKEND=local
# SQLITE_URL defaults to backend/storage/app.db when omitted.
# SQLITE_URL=sqlite:////absolute/path/to/app.db
# METADATA_BACKEND=postgres
# POSTGRES_URL=postgresql+psycopg://user:password@localhost:5432/agentcad
# METADATA_BACKEND=supabase
# SUPABASE_DB_URL=postgresql+psycopg://postgres:password@db.project-ref.supabase.co:5432/postgres

# ============================================================================
# VIDEO STORAGE
# ============================================================================
# local serves videos from backend/storage/videos through /api/videos/{name}.
VIDEO_STORAGE_BACKEND=local
# VIDEO_PUBLIC_BASE_URL=http://127.0.0.1:8000/api/videos

# MinIO/S3-compatible storage for rendered MP4 files.
# VIDEO_STORAGE_BACKEND=minio
# MINIO_ENDPOINT=127.0.0.1:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_BUCKET=agentcad-videos
# MINIO_SECURE=false
# VIDEO_PUBLIC_BASE_URL=http://127.0.0.1:9000/agentcad-videos
